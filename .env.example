APP_NAME=ISL Recognition System
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=isl-recognition-secret-key-change-in-production-2026

BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=sqlite+aiosqlite:///./isl_dev.db

REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

MODELS_DIR=../ml/models
STATIC_MODEL_PATH=../ml/models/static_classifier
DYNAMIC_MODEL_PATH=../ml/models/dynamic_classifier
SENTENCE_MODEL_PATH=../ml/models/sentence_model

MEDIAPIPE_MIN_DETECTION_CONFIDENCE=0.7
MEDIAPIPE_MIN_TRACKING_CONFIDENCE=0.5

RATE_LIMIT_PER_MINUTE=60
MAX_UPLOAD_SIZE_MB=200
UPLOAD_DIR=./uploads

VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
